# Shell scripts must keep LF endings — they run on Linux (Chroma VM, containers).
# Without this, Windows checkouts get CRLF and bash chokes on the trailing \r.
*.sh text eol=lf

# Normalize text sources to LF in the repo regardless of checkout platform.
*.md   text eol=lf
*.py   text eol=lf
*.json text eol=lf

# PowerShell helpers are Windows-only; keep CRLF.
*.ps1 text eol=crlf

# Binary assets — never diff or line-ending-convert.
*.gif binary
*.png binary
*.jpg binary
*.parquet binary
